{
  "manifest_version": 3,

  "name": "PhantomClick",
  "version": "1.0",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "tabCapture"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "scripts/background.js"
  },
  "action": {
    "default_popup": "index.html"
  }
}